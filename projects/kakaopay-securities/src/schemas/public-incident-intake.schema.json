{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.axwar.invalid/kps-public-incident-intake.schema.json",
  "title": "Kakao Pay Securities Public Incident Intake",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "observed_window",
    "public_reports",
    "official_sources"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "case_id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9-]{2,79}$"
    },
    "observed_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {"type": "string", "format": "date-time"},
        "end": {"type": "string", "format": "date-time"}
      }
    },
    "public_reports": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/publicReport"}
    },
    "official_sources": {
      "type": "array",
      "items": {"$ref": "#/$defs/officialSource"}
    }
  },
  "$defs": {
    "isoDateOrDateTime": {
      "oneOf": [
        {"type": "string", "format": "date"},
        {"type": "string", "format": "date-time"}
      ]
    },
    "commonSourceProperties": {
      "type": "object",
      "properties": {
        "evidence_id": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9._:-]{2,127}$"
        },
        "source_record_id": {"type": "string", "minLength": 1},
        "source_url": {"type": "string", "pattern": "^https://"},
        "source_type": {"type": "string"},
        "published_at": {"$ref": "#/$defs/isoDateOrDateTime"},
        "captured_at": {"type": "string", "format": "date-time"},
        "text": {"type": "string", "minLength": 1}
      },
      "required": [
        "evidence_id",
        "source_record_id",
        "source_url",
        "source_type",
        "published_at",
        "captured_at",
        "text"
      ]
    },
    "publicReport": {
      "allOf": [
        {"$ref": "#/$defs/commonSourceProperties"},
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "evidence_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._:-]{2,127}$"},
            "source_record_id": {"type": "string", "minLength": 1},
            "source_url": {"type": "string", "pattern": "^https://"},
            "source_type": {
              "enum": ["google_play_review", "apple_app_store_review", "other_public_report"]
            },
            "published_at": {"$ref": "#/$defs/isoDateOrDateTime"},
            "captured_at": {"type": "string", "format": "date-time"},
            "text": {"type": "string", "minLength": 1},
            "rating": {"type": "integer", "minimum": 1, "maximum": 5},
            "platform": {"enum": ["android", "ios", "web", "other"]},
            "app_version": {"type": "string", "minLength": 1},
            "is_edited": {"type": "boolean"},
            "device_os": {"type": "string", "minLength": 1},
            "network": {"type": "string", "minLength": 1},
            "exact_occurred_at": {"type": "string", "format": "date-time"},
            "reproduction_steps": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            },
            "expected_result": {"type": "string", "minLength": 1},
            "actual_result": {"type": "string", "minLength": 1}
          },
          "required": [
            "evidence_id",
            "source_record_id",
            "source_url",
            "source_type",
            "published_at",
            "captured_at",
            "text"
          ]
        }
      ]
    },
    "officialSource": {
      "allOf": [
        {"$ref": "#/$defs/commonSourceProperties"},
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "evidence_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._:-]{2,127}$"},
            "source_record_id": {"type": "string", "minLength": 1},
            "source_url": {"type": "string", "pattern": "^https://"},
            "source_type": {
              "enum": ["kps_official_notice", "public_standard", "public_market_notice"]
            },
            "published_at": {"$ref": "#/$defs/isoDateOrDateTime"},
            "captured_at": {"type": "string", "format": "date-time"},
            "text": {"type": "string", "minLength": 1}
          },
          "required": [
            "evidence_id",
            "source_record_id",
            "source_url",
            "source_type",
            "published_at",
            "captured_at",
            "text"
          ]
        }
      ]
    }
  }
}
